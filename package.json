{
  "name": "ereks-everquest-parser",
  "version": "1.0.0",
  "description": "Erek's Everquest Parser — native Linux EQ log parser with DPS meter, buff timers, and audio triggers",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox --disable-gpu-sandbox",
    "start-gpu": "electron .",
    "build": "electron-builder --linux AppImage",
    "screenshot": "node scripts/screenshot.js"
  },
  "keywords": [
    "everquest",
    "eq",
    "parser",
    "dps",
    "linux"
  ],
  "author": "Paul",
  "license": "MIT",
  "dependencies": {
    "chokidar": "^3.6.0",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "playwright": "^1.59.1"
  },
  "build": {
    "appId": "com.ereks.everquest.parser",
    "productName": "Erek's Everquest Parser",
    "linux": {
      "target": "AppImage",
      "category": "Game"
    }
  }
}
